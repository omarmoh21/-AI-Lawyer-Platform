GEMINI_API_KEY=
ELEVENLABS_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=

# Dense embeddings server (TEI). Defaults to the local docker-compose service.
TEI_EMBED_URL=http://localhost:8080/embed

# Reranking (Cohere). Best-effort — off by default; falls back to RRF order if
# disabled or unavailable (429/quota/network). Trial key allows ~10 req/min.
RERANK_ENABLED=false
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# Auth — set a long random string in production
JWT_SECRET_KEY=dev-insecure-secret-change-me

# Optional — LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-lawyer
